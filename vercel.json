{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/src/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/artifacts/nova-store/dist/public/index.html"
    }
  ],
  "builds": [
    {
      "src": "artifacts/nova-store/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public"
      }
    },
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node"
    }
  ]
}
